rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId);

      match /meal_logs/{mealLogId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && request.resource.data.userId == userId
          && request.resource.data.mealName is string
          && request.resource.data.mealType is string
          && request.resource.data.portion is string
          && request.resource.data.source is string
          && request.resource.data.calories is int;
      }
    }

    match /community_posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.tag is string
        && request.resource.data.username is string;
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}
